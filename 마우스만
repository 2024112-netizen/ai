<!DOCTYPE html>
<html lang="ko">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>AI 비전: 마우스 전용 스캐너_원희</title>

    <!-- ONNX Runtime Web JS -->
    <script src="https://cdn.jsdelivr.net/npm/onnxruntime-web/dist/ort.min.js"></script>

    <style>
        body {
            font-family: 'Segoe UI', Roboto, 'Malgun Gothic', sans-serif;
            margin: 0;
            padding: 20px;
            background: radial-gradient(circle at center, #141b24 0%, #070a0e 100%);
            color: #f8fafc;
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            min-height: 100vh;
            box-sizing: border-box;
            overflow-x: hidden;
        }

        .app-wrapper {
            width: 100%;
            max-width: 540px;
            display: flex;
            flex-direction: column;
            align-items: center;
        }

        h1 {
            font-size: 1.8rem;
            font-weight: 800;
            margin: 0 0 5px 0;
            background: linear-gradient(135deg, #10b981 0%, #059669 100%);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            text-shadow: 0 0 20px rgba(16, 185, 129, 0.2);
            text-align: center;
            letter-spacing: -0.5px;
        }

        p {
            font-size: 0.85rem;
            color: #64748b;
            margin-top: 0;
            margin-bottom: 25px;
            font-weight: 600;
            letter-spacing: 2px;
            text-transform: uppercase;
        }

        /* 상태 표시창 */
        #status-container {
            display: flex;
            align-items: center;
            gap: 10px;
            background: rgba(15, 23, 42, 0.8);
            backdrop-filter: blur(10px);
            padding: 10px 24px;
            border-radius: 100px;
            font-size: 13px;
            font-weight: 700;
            border: 1px solid rgba(255, 255, 255, 0.05);
            margin-bottom: 20px;
            box-shadow: 0 10px 25px rgba(0,0,0,0.4);
            color: #94a3b8;
            transition: all 0.2s ease;
        }

        /* LED 인디케이터 효과 */
        .led-dot {
            width: 8px;
            height: 8px;
            border-radius: 50%;
            display: inline-block;
        }
        .led-loading { background-color: #f59e0b; box-shadow: 0 0 10px #f59e0b; animation: blink 1s infinite; }
        .led-active { background-color: #64748b; box-shadow: 0 0 8px #64748b; }
        .led-locked { background-color: #ef4444; box-shadow: 0 0 15px #ef4444; animation: blink 0.4s infinite; }
        .led-error { background-color: #ef4444; box-shadow: 0 0 10px #ef4444; }

        @keyframes blink {
            0%, 100% { opacity: 0.3; }
            50% { opacity: 1; }
        }

        /* 디스플레이 비전 박스 */
        #canvas-container {
            position: relative;
            width: 100%;
            aspect-ratio: 4 / 3;
            background: #020408;
            border-radius: 24px;
            overflow: hidden;
            box-shadow: 0 30px 60px rgba(0, 0, 0, 0.7);
            border: 2px solid rgba(255, 255, 255, 0.03);
        }

        video { display: none; }

        canvas {
            position: absolute;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            object-fit: cover;
        }
    </style>
</head>
<body>

    <div class="app-wrapper">
        <h1>🔍 MOUSE TARGET FINDER</h1>
        <p>Target Object: Computer Mouse</p>

        <!-- 상태창 -->
        <div id="status-container">
            <span id="led" class="led-dot led-loading"></span>
            <span id="status-text">SYSTEM LOADING...</span>
        </div>

        <!-- 메인 디스플레이 비전 박스 -->
        <div id="canvas-container">
            <video id="webcam" autoplay playsinline muted></video>
            <canvas id="display_canvas"></canvas>
        </div>
    </div>

    <script>
        const video = document.getElementById('webcam');
        const canvas = document.getElementById('display_canvas');
        const ctx = canvas.getContext('2d');
        const statusText = document.getElementById('status-text');
        const led = document.getElementById('led');

        let session;
        const modelWidth = 640;
        const modelHeight = 640;

        // 전체 라벨 데이터
        const labels = ["person", "bicycle", "car", "motorcycle", "airplane", "bus", "train", "truck", "boat", "traffic light", "fire hydrant", "stop sign", "parking meter", "bench", "bird", "cat", "dog", "horse", "sheep", "cow", "elephant", "bear", "zebra", "giraffe", "backpack", "umbrella", "handbag", "tie", "suitcase", "frisbee", "skis", "snowboard", "sports ball", "kite", "baseball bat", "baseball glove", "skateboard", "surfboard", "tennis racket", "bottle", "wine glass", "cup", "fork", "knife", "spoon", "bowl", "banana", "apple", "sandwich", "orange", "broccoli", "carrot", "hot dog", "pizza", "donut", "cake", "chair", "couch", "potted plant", "bed", "dining table", "toilet", "tv", "laptop", "mouse", "remote", "keyboard", "cell phone", "microwave", "oven", "toaster", "sink", "refrigerator", "book", "clock", "vase", "scissors", "teddy bear", "hair drier", "toothbrush"];
        
        // 오직 'mouse'만 필터링하기 위한 인덱스 찾기
        const targetClassId = labels.indexOf("mouse"); 

        async function startApp() {
            try {
                const stream = await navigator.mediaDevices.getUserMedia({
                    video: { facingMode: { ideal: "environment" }, width: { ideal: 640 }, height: { ideal: 480 } },
                    audio: false
                });
                video.srcObject = stream;
                await video.play();

                statusText.innerText = "⚡ OPTIMIZING GPU ACCELERATION...";
                session = await ort.InferenceSession.create('yolov8n.onnx', { executionProviders: ['webgl', 'wasm'] });

                // 마우스 탐색 대기 상태 설정
                led.className = "led-dot led-active";
                statusText.innerText = "📡 MOUSE SCANNING SYSTEM ONLINE";
                statusText.style.color = "#94a3b8";

                canvas.width = video.videoWidth;
                canvas.height = video.videoHeight;

                requestAnimationFrame(processFrame);
            } catch (err) {
                led.className = "led-dot led-error";
                statusText.innerText = "❌ CAMERA ERROR: ACCESS DENIED";
                statusText.style.color = "#ef4444";
                console.error(err);
            }
        }

        async function processFrame() {
            if (video.readyState === video.HAVE_ENOUGH_DATA) {
                ctx.drawImage(video, 0, 0, canvas.width, canvas.height);
                const inputTensor = preprocess(video, modelWidth, modelHeight);

                if (inputTensor) {
                    try {
                        const outputs = await session.run({ images: inputTensor });
                        const output = outputs[Object.keys(outputs)[0]];
                        postprocess(output.data, output.dims);
                    } catch (e) {
                        console.error(e);
                    }
                }
            }
            requestAnimationFrame(processFrame);
        }

        function preprocess(img, width, height) {
            const tempCanvas = document.createElement('canvas');
            tempCanvas.width = width;
            tempCanvas.height = height;
            const tempCtx = tempCanvas.getContext('2d');
            tempCtx.drawImage(img, 0, 0, width, height);

            const imgData = tempCtx.getImageData(0, 0, width, height);
            const data = imgData.data;

            const r = new Float32Array(width * height);
            const g = new Float32Array(width * height);
            const b = new Float32Array(width * height);

            for (let i = 0; i < data.length / 4; i++) {
                r[i] = data[i * 4] / 255.0;
                g[i] = data[i * 4 + 1] / 255.0;
                b[i] = data[i * 4 + 2] / 255.0;
            }

            const float32Data = new Float32Array(width * height * 3);
            float32Data.set(r, 0);
            float32Data.set(g, width * height);
            float32Data.set(b, width * height * 2);

            return new ort.Tensor('float32', float32Data, [1, 3, width, height]);
        }

        function postprocess(data, dims) {
            const numAttributes = dims[1];
            const numBoxes = dims[2];
            let mouseDetected = false;

            for (let i = 0; i < numBoxes; i += 12) {
                let maxScore = 0;
                let classId = -1;

                for (let c = 4; c < numAttributes; c++) {
                    const score = data[c * numBoxes + i];
                    if (score > maxScore) {
                        maxScore = score;
                        classId = c - 4;
                    }
                }

                // 🔥 핵심 조건 설정: 신뢰도가 높고 탐지된 대상이 오직 '마우스'일 때만 수행
                if (maxScore > 0.45 && classId === targetClassId) {
                    mouseDetected = true;

                    const cx = data[0 * numBoxes + i] / modelWidth * canvas.width;
                    const cy = data[1 * numBoxes + i] / modelHeight * canvas.height;
                    const w = data[2 * numBoxes + i] / modelWidth * canvas.width;
                    const h = data[3 * numBoxes + i] / modelHeight * canvas.height;

                    const x = cx - w / 2;
                    const y = cy - h / 2;

                    // 마우스 포착용 강렬한 네온 레드/오렌지 테마 컬러
                    const themeColor = "#ff4a4a"; 
                    const cornerLength = Math.min(w, h) * 0.15;

                    // 1. 타겟 추적 박스 아웃라인
                    ctx.strokeStyle = "rgba(255, 74, 74, 0.25)";
                    ctx.lineWidth = 1.5;
                    ctx.strokeRect(x, y, w, h);

                    // 2. 조준점 느낌의 볼드 꺾쇠 그리기
                    ctx.strokeStyle = themeColor;
                    ctx.lineWidth = 4;
                    ctx.lineCap = "round";

                    // 좌상단
                    ctx.beginPath(); ctx.moveTo(x + cornerLength, y); ctx.lineTo(x, y); ctx.lineTo(x, y + cornerLength); ctx.stroke();
                    // 우상단
                    ctx.beginPath(); ctx.moveTo(x + w - cornerLength, y); ctx.lineTo(x + w, y); ctx.lineTo(x + w, y + cornerLength); ctx.stroke();
                    // 좌하단
                    ctx.beginPath(); ctx.moveTo(x, y + h - cornerLength); ctx.lineTo(x, y + h); ctx.lineTo(x + cornerLength, y + h); ctx.stroke();
                    // 우하단
                    ctx.beginPath(); ctx.moveTo(x + w - cornerLength, y + h); ctx.lineTo(x + w, y + h); ctx.lineTo(x + w, y + h - cornerLength); ctx.stroke();

                    // 3. TARGET LOCKED 라벨 상자 배너
                    const text = `🎯 MOUSE TARGET LOCKED [${Math.round(maxScore * 100)}%]`;
                    ctx.font = "bold 11px 'Segoe UI', sans-serif";
                    const textWidth = ctx.measureText(text).width;
                    const paddingX = 10;
                    const boxHeight = 22;

                    ctx.fillStyle = themeColor;
                    ctx.beginPath();
                    ctx.roundRect(x - 1, y - boxHeight - 2, textWidth + paddingX * 2, boxHeight, [4, 4, 0, 0]);
                    ctx.fill();

                    // 4. 라벨 내 글씨 쓰기
                    ctx.fillStyle = "#ffffff";
                    ctx.fillText(text, x + paddingX, y - 8);
                }
            }

            // 실시간 탐지 상태에 따른 상단 상태 콤포넌트 변화 제어
            if (mouseDetected) {
                led.className = "led-dot led-locked";
                statusText.innerText = "🎯 MOUSE TARGET LOCKED";
                statusText.style.color = "#ff4a4a";
            } else {
                if (session) { // 세션 로드가 정상 완료된 경우만
                    led.className = "led-dot led-active";
                    statusText.innerText = "📡 MOUSE SCANNING SYSTEM ONLINE";
                    statusText.style.color = "#94a3b8";
                }
            }
        }

        window.onload = startApp;
    </script>
</body>
</html>
